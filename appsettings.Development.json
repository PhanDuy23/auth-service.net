{
  "AppSettings": {
    "BaseUrl": "http://localhost:5000"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=authdb;Username=authuser;Password=authdbpassword"
  },
  "JwtSettings": {
    "SecretKey": "dev-secret-key-replace-in-production-min32chars",
    "Issuer": "auth-service",
    "Audience": "auth-service-clients",
    "ExpiryMinutes": 30,
    "RefreshTokenExpiryHours": 24
  },
  "IdentitySettings": {
    "RequireDigit": true,
    "RequireLowercase": true,
    "RequireUppercase": true,
    "RequiredLength": 8,
    "MaxFailedAccessAttempts": 5,
    "DefaultLockoutMinutes": 15
  },
  "EmailSettings": {
    "SmtpServer": "smtp.gmail.com",
    "Port": 587,
    "SenderName": "Auth Service",
    "SenderEmail": "yourmail@gmail.com",
    "Username": "yourmail@gmail.com",
    "Password": "app-password"
  }
}